// Convert to grayscale if RGB
if ndims(I) == 3 then
 I = rgb2gray(I);
end
// Get image size
[rows, cols] = size(I);
// Gaussian Low Pass mask
mask = [1 2 1;
 2 4 2;
 1 2 1] / 16;
// Laplacian High Pass mask
mask2 = [1 1 1;
 1 -8 1;
 1 1 1];
// Initialize output images
laplacian_img = zeros(rows, cols);
smooth_img = zeros(rows, cols);
// Apply filters
for i = 2:rows-1
