 I(i,j-1)*mask(2,1) + I(i,j)*mask(2,2) + I(i,j+1)*mask(2,3) +
 I(i+1,j-1)*mask(3,1) + I(i+1,j)*mask(3,2) + I(i+1,j+1)*mask(3,3);
 // Laplacian filter
 laplacian_img(i,j) =
 I(i-1,j-1)*mask2(1,1) + I(i-1,j)*mask2(1,2) + I(i-1,j+1)*mask2(1,3) +
