Circular Convolution
clc;
clear;
// Input
x = input("Enter Input: ");
y = input("Enter Impulse: ");
x=ascii(string(x))-48;
y=ascii(string(y))-48;

n1 = length(x);
n2 = length(y);
// Make both signals same length
if n1 > n2 then
y = [y zeros(1, n1 - n2)];
elseif n2 > n1 then
x = [x zeros(1, n2 - n1)];
end
N = length(x);
g = zeros(1, N);// Circular convolution
for n = 1:N
for k = 1:N
idx = modulo(n - k + N, N) + 1;
g(n) = g(n) + x(k) * y(idx);
end
end
// Display
disp(g);
// Index
ny = 0:N-1;
// Plot
scf(1);
subplot(3,1,1);
plot(ny, x, '-o');
title("Input x(n) (padded)");
subplot(3,1,2);
plot(ny, y, '-o');
title("Impulse y(n) (padded)");
subplot(3,1,3);
plot(ny, g, '-o');
title("Circular Convolution y(n)");
