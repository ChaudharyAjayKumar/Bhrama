// Read image
I = imread("cameraman.tif");

// Convert to double
I = im2double(I);

// Get size
[rows, cols] = size(I);

// Initialize output
Robert = zeros(rows, cols);

// Roberts masks
Gx = [1 0;
      0 -1];

Gy = [0 1;
     -1 0];

// Apply Roberts operator
for i = 1:rows-1
    for j = 1:cols-1
        
        gx = I(i,j)*Gx(1,1) + I(i,j+1)*Gx(1,2) + ...
             I(i+1,j)*Gx(2,1) + I(i+1,j+1)*Gx(2,2);
         
        gy = I(i,j)*Gy(1,1) + I(i,j+1)*Gy(1,2) + ...
             I(i+1,j)*Gy(2,1) + I(i+1,j+1)*Gy(2,2);
         
        // Gradient magnitude
        Robert(i,j) = sqrt(gx^2 + gy^2);
        
    end
end

// Display output
figure

subplot(1,2,1)
imshow(I)
title("Original Image")

subplot(1,2,2)
imshow(uint8(Robert))
title("Roberts Edge Detection")