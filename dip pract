clear;

// Read image
I = imread("D:\image.jpeg");

// Convert to grayscale if needed
I = rgb2gray(I);

// Convert to double
I = double(I);

// Get size
[rows, cols] = size(I);

// ---------------- BLUR ----------------

// Initialize blurred image
blurred = zeros(rows, cols);

// Apply 3x3 averaging filter
for i = 2:rows-1
    for j = 2:cols-1
        
        blurred(i,j) = ( ...
            I(i-1,j-1) + I(i-1,j) + I(i-1,j+1) + ...
            I(i,j-1)   + I(i,j)   + I(i,j+1) + ...
            I(i+1,j-1) + I(i+1,j) + I(i+1,j+1) ...
        ) / 9;
        
    end
end

// ---------------- DETAIL EXTRACTION ----------------

// Detail (mask)
detail = I - blurred;

// ---------------- ENHANCEMENT ----------------

// Scaling factor
k = 1;

// Enhanced image
enhanced = I + k * detail;

// ---------------- DISPLAY ----------------

figure(1);

// Original
subplot(2,2,1);
imshow(uint8(I));
title("Original Image");

// Blurred
subplot(2,2,2);
imshow(uint8(blurred));
title("Blurred Image");

// Mask (detail)
subplot(2,2,3);
imshow(uint8(detail + 128));   // shift for visibility
title("Mask Image");

// Enhanced
subplot(2,2,4);
imshow(uint8(enhanced));
title("Enhanced Image");

