// Create empty sampled image (smaller size)
im_sampled = zeros(floor(row/n), floor(col/n));
// ---------------- SAMPLING LOGIC ----------------// Loop through sampled image indices
for i = 1:floor(row/n)
for j = 1:floor(col/n)
// Calculate original image position
// (i-1)*n + 1 → start of each block
r = (i-1)*n + 1;
c = (j-1)*n + 1;
// Use min() to avoid index going out of bounds
r = min(r, row);
c = min(c, col);
// Assign sampled pixel
im_sampled(i,j) = I(r, c);
end
end
// ---------------- DISPLAY ----------------
